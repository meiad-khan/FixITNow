model User {
  id                String             @id @default(uuid())
  name              String
  email             String             @unique
  phone             String?            @unique
  password          String
  role              Role               @default(CUSTOMER)
  userStatus        UserStatus         @default(UNBAN)
  technicianProfile TechnicianProfile?
  bookings          Booking[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@map("users")
}
